<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="viper_base_stake_id">Base Stake</variable>
    <variable id="viper_mf_id">Martingale Factor</variable>
    <variable id="viper_tp_id">Take Profit</variable>
    <variable id="viper_sl_id">Stop Loss</variable>
    <variable id="viper_profit_id">Total Profit</variable>
  </variables>

  <!-- ── trade_definition ─────────────────────────────────────────────── -->
  <block type="trade_definition" id="viper_trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="viper_market" deletable="false" movable="false">
        <mutation xmlns="http://www.w3.org/1999/xhtml" vh_enabled="false" vh_max_steps="1" vh_min_trades="1" vh_stake="0.35"></mutation>
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_25</field>
        <field name="ALTERNATE_MARKETS">FALSE</field>
        <field name="ALTERNATE_EVERY">1</field>
        <field name="MULTI_MARKET">FALSE</field>
        <field name="VH_ENABLED">FALSE</field>
        <field name="VH_SETTINGS_BTN">VH Settings</field>
        <next>
          <block type="trade_definition_tradetype" id="viper_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">overunder</field>
            <next>
              <block type="trade_definition_contracttype" id="viper_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="viper_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="viper_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="viper_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <block type="variables_set" id="viper_init_bs">
        <field name="VAR" id="viper_base_stake_id">Base Stake</field>
        <value name="VALUE">
          <block type="math_number" id="viper_bs_num">
            <field name="NUM">0.35</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="viper_init_mf">
            <field name="VAR" id="viper_mf_id">Martingale Factor</field>
            <value name="VALUE">
              <block type="math_number" id="viper_mf_num">
                <field name="NUM">2.1</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="viper_init_tp">
                <field name="VAR" id="viper_tp_id">Take Profit</field>
                <value name="VALUE">
                  <block type="math_number" id="viper_tp_num">
                    <field name="NUM">50</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="viper_init_sl">
                    <field name="VAR" id="viper_sl_id">Stop Loss</field>
                    <value name="VALUE">
                      <block type="math_number" id="viper_sl_num">
                        <field name="NUM">20</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="viper_init_profit">
                        <field name="VAR" id="viper_profit_id">Total Profit</field>
                        <value name="VALUE">
                          <block type="math_number" id="viper_profit_num">
                            <field name="NUM">0</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <!-- trade_definition_tradeoptions goes in SUBMARKET, not PURCHASE_OPTIONS -->
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="viper_tradeoptions" deletable="false" movable="false">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="viper_dur_shadow">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="viper_amt_shadow">
            <field name="NUM">0.35</field>
          </shadow>
          <block type="variables_get" id="viper_stake_get">
            <field name="VAR" id="viper_base_stake_id">Base Stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="viper_pred_shadow">
            <field name="NUM">4</field>
          </shadow>
        </value>
      </block>
    </statement>
  </block>

  <!-- ── before_purchase — separate top-level block ───────────────────── -->
  <block type="before_purchase" id="viper_before_purchase" deletable="false" x="0" y="1154">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="viper_purchase" id="viper_purchase_block">
        <value name="BASE_STAKE">
          <block type="variables_get" id="viper_get_bs">
            <field name="VAR" id="viper_base_stake_id">Base Stake</field>
          </block>
        </value>
        <value name="MARTINGALE_FACTOR">
          <block type="variables_get" id="viper_get_mf">
            <field name="VAR" id="viper_mf_id">Martingale Factor</field>
          </block>
        </value>
      </block>
    </statement>
  </block>

  <!-- ── after_purchase — separate top-level block ────────────────────── -->
  <block type="after_purchase" id="viper_after_purchase" x="1051" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="viper_on_result" id="viper_on_result_block">
        <next>
          <block type="variables_set" id="viper_update_profit">
            <field name="VAR" id="viper_profit_id">Total Profit</field>
            <value name="VALUE">
              <block type="math_arithmetic" id="viper_add_profit">
                <field name="OP">ADD</field>
                <value name="A">
                  <block type="variables_get" id="viper_get_profit">
                    <field name="VAR" id="viper_profit_id">Total Profit</field>
                  </block>
                </value>
                <value name="B">
                  <block type="read_details" id="viper_read_profit">
                    <field name="DETAIL_INDEX">4</field>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <!-- if TP reached → notify + stop, else check SL, else trade again -->
              <block type="controls_if" id="viper_tp_check">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="viper_tp_cmp">
                    <field name="OP">GTE</field>
                    <value name="A">
                      <block type="variables_get" id="viper_profit_tp">
                        <field name="VAR" id="viper_profit_id">Total Profit</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="variables_get" id="viper_tp_val">
                        <field name="VAR" id="viper_tp_id">Take Profit</field>
                      </block>
                    </value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="notify" id="viper_tp_notify">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <field name="NOTIFICATION_SOUND">silent</field>
                    <value name="MESSAGE">
                      <block type="text" id="viper_tp_msg">
                        <field name="TEXT">Volatility Viper: Take Profit reached! Bot stopped.</field>
                      </block>
                    </value>
                  </block>
                </statement>
                <statement name="ELSE">
                  <block type="controls_if" id="viper_sl_check">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0">
                      <block type="logic_compare" id="viper_sl_cmp">
                        <field name="OP">LTE</field>
                        <value name="A">
                          <block type="variables_get" id="viper_profit_sl">
                            <field name="VAR" id="viper_profit_id">Total Profit</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_arithmetic" id="viper_sl_neg">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="viper_sl_val">
                                <field name="VAR" id="viper_sl_id">Stop Loss</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="viper_neg_one">
                                <field name="NUM">-1</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="notify" id="viper_sl_notify">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <block type="text" id="viper_sl_msg">
                            <field name="TEXT">Volatility Viper: Stop Loss hit! Bot stopped.</field>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <block type="trade_again" id="viper_trade_again"></block>
                    </statement>
                  </block>
                </statement>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
